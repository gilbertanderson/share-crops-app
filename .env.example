# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.

# Supabase project reference ID (found in your Supabase project settings)
VITE_SUPABASE_PROJECT_ID=your_project_id_here

# Supabase public anon key (safe to expose in frontend)
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Full API base URL (constructed from project ID above)
VITE_API_URL=https://your_project_id_here.supabase.co/functions/v1

# App base URL (used for auth redirects — set to your deployed domain in production)
VITE_APP_URL=http://localhost:5173
